<Window x:Class="DynamicIsland.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dynamic Island"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="Manual"
        Width="420" Height="300"
        WindowStartupLocation="Manual">

    <Window.Resources>
        <Style x:Key="MediaBtn" TargetType="Button">
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="19">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.FontSize="{TemplateBinding FontSize}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#22FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MediaBtnBig" TargetType="Button" BasedOn="{StaticResource MediaBtn}">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="FontSize" Value="18"/>
        </Style>

        <Style x:Key="GearBtn" TargetType="Button" BasedOn="{StaticResource MediaBtn}">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource SubTextBrush}"/>
        </Style>

        <Style x:Key="TabBtn" TargetType="Button" BasedOn="{StaticResource MediaBtn}">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="Foreground" Value="{StaticResource SubTextBrush}"/>
        </Style>

        <Style x:Key="PillBtn" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="MinWidth" Value="44"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="15" Padding="12,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#FF2C2C2C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingItem" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="8" Padding="10,0">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#1AFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Border x:Name="Shell"
                VerticalAlignment="Top" HorizontalAlignment="Center"
                CornerRadius="0,0,22,22" Background="{StaticResource IslandBrush}">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="26" ShadowDepth="0" Opacity="0.5"/>
            </Border.Effect>

            <Border x:Name="Island"
                    Background="{StaticResource IslandBrush}"
                    CornerRadius="0,0,22,22"
                    Width="200" Height="34"
                    ClipToBounds="True"
                    AllowDrop="True"
                    MouseEnter="Island_MouseEnter"
                    MouseLeave="Island_MouseLeave"
                    MouseLeftButtonUp="Island_Click"
                    DragEnter="Island_DragEnter"
                    DragOver="Island_DragOver"
                    Drop="Island_Drop">
                <Grid>
                    <Grid x:Name="CompactView" Margin="14,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="18" Height="18" CornerRadius="5"
                                Background="#FF1E1E1E" VerticalAlignment="Center" Margin="0,0,8,0">
                            <Image x:Name="CompactArt" Stretch="UniformToFill"/>
                        </Border>
                        <TextBlock x:Name="CompactClock" Grid.Column="1" Text="--:--"
                                   Foreground="{StaticResource TextBrush}" FontSize="14" FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"
                                    Margin="8,0,0,0" x:Name="CompactBars">
                            <Rectangle Width="3" Height="8"  Fill="{StaticResource AccentBrush}" RadiusX="1.5" RadiusY="1.5" Margin="1,0"/>
                            <Rectangle Width="3" Height="14" Fill="{StaticResource AccentBrush}" RadiusX="1.5" RadiusY="1.5" Margin="1,0"/>
                            <Rectangle Width="3" Height="6"  Fill="{StaticResource AccentBrush}" RadiusX="1.5" RadiusY="1.5" Margin="1,0"/>
                        </StackPanel>
                    </Grid>

                    <Grid x:Name="ExpandedView" Margin="18,12" Opacity="0" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Button x:Name="TabMediaBtn" Content="&#xE8D6;" Click="TabMedia_Click" Style="{StaticResource TabBtn}"/>
                                <Button x:Name="TabTimerBtn" Content="&#xE916;" Click="TabTimer_Click" Style="{StaticResource TabBtn}"/>
                                <Button x:Name="TabFilesBtn" Content="&#xE8B7;" Click="TabFiles_Click" Style="{StaticResource TabBtn}"/>
                            </StackPanel>
                            <Button x:Name="GearBtn" Content="&#xE713;" HorizontalAlignment="Right"
                                    VerticalAlignment="Top" Click="Settings_Click" Style="{StaticResource GearBtn}"/>
                        </Grid>

                        <Grid Grid.Row="1">
                            <Grid x:Name="MediaPanel">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="52" Height="52" CornerRadius="12"
                                            Background="#FF1E1E1E" Margin="0,0,12,0">
                                        <Image x:Name="AlbumArt" Stretch="UniformToFill"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock x:Name="TrackTitle" Text="Aucune lecture"
                                                   Foreground="{StaticResource TextBrush}" FontSize="14" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock x:Name="TrackArtist" Text="—"
                                                   Foreground="{StaticResource SubTextBrush}" FontSize="12"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Grid>
                                <Grid Grid.Row="1" Margin="0,12,0,0">
                                    <Border Height="4" CornerRadius="2" Background="#FF2A2A2A"/>
                                    <Border x:Name="ProgressFill" Height="4" CornerRadius="2"
                                            Background="{StaticResource TextBrush}" HorizontalAlignment="Left" Width="0"/>
                                </Grid>
                                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center"
                                            VerticalAlignment="Center" Margin="0,6">
                                    <Button x:Name="PrevBtn" Content="&#xE892;" Click="Prev_Click" Style="{StaticResource MediaBtn}"/>
                                    <Button x:Name="PlayBtn" Content="&#xE768;" Click="PlayPause_Click" Style="{StaticResource MediaBtnBig}"/>
                                    <Button x:Name="NextBtn" Content="&#xE893;" Click="Next_Click" Style="{StaticResource MediaBtn}"/>
                                </StackPanel>
                            </Grid>

                            <StackPanel x:Name="TimerPanel" Visibility="Collapsed" VerticalAlignment="Center">
                                <TextBlock x:Name="TimerDisplay" Text="00:00" HorizontalAlignment="Center"
                                           Foreground="{StaticResource TextBrush}" FontSize="38" FontWeight="Light"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                                    <Button Content="+1 min" Click="TimerPlus1_Click" Style="{StaticResource PillBtn}"/>
                                    <Button Content="+5 min" Click="TimerPlus5_Click" Style="{StaticResource PillBtn}"/>
                                    <Button Content="+10 min" Click="TimerPlus10_Click" Style="{StaticResource PillBtn}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                                    <Button x:Name="TimerStartBtn" Content="Démarrer" Click="TimerStartPause_Click" Style="{StaticResource PillBtn}"/>
                                    <Button Content="Réinit." Click="TimerReset_Click" Style="{StaticResource PillBtn}"/>
                                </StackPanel>
                            </StackPanel>

                            <Grid x:Name="FilesPanel" Visibility="Collapsed">
                                <TextBlock x:Name="ShelfHint" Text="Glisse des fichiers ici"
                                           Foreground="{StaticResource SubTextBrush}" FontSize="13"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                    <WrapPanel x:Name="ShelfPanel"/>
                                </ScrollViewer>
                            </Grid>
                        </Grid>

                        <Grid Grid.Row="2" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock x:Name="ClockText" Text="--:--"
                                           Foreground="{StaticResource TextBrush}" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock x:Name="DateText" Text="—"
                                           Foreground="{StaticResource SubTextBrush}" FontSize="11"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <StackPanel x:Name="BtPanel" Orientation="Horizontal" VerticalAlignment="Center"
                                            Margin="0,0,12,0" Visibility="Collapsed">
                                    <TextBlock x:Name="BtIcon" Text="&#xE7F6;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               Foreground="{StaticResource TextBrush}" FontSize="13"
                                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock x:Name="BtText" Text="--%"
                                               Foreground="{StaticResource TextBrush}" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock x:Name="BatteryIcon" Text="🔋" FontSize="14" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock x:Name="BatteryText" Text="--%"
                                           Foreground="{StaticResource TextBrush}" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <Border x:Name="SettingsPanel" Background="{StaticResource IslandBrush}"
                            CornerRadius="0,0,32,32" Visibility="Collapsed">
                        <StackPanel Margin="18,12">
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="Réglages" Foreground="{StaticResource TextBrush}"
                                           FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <Button x:Name="CloseSettingsBtn" Content="&#xE711;" HorizontalAlignment="Right"
                                        Click="CloseSettings_Click" Style="{StaticResource GearBtn}"/>
                            </Grid>
                            <Button x:Name="RecenterBtn" Content="Recentrer en haut" Click="Recenter_Click" Style="{StaticResource SettingItem}"/>
                            <Button x:Name="AutoStartBtn" Content="Démarrage avec Windows" Click="AutoStart_Click" Style="{StaticResource SettingItem}"/>
                            <Button x:Name="QuitBtn" Content="Quitter" Click="Quit_Click" Style="{StaticResource SettingItem}" Foreground="#FFFF6B6B"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="FirstRunPanel" Background="{StaticResource IslandBrush}"
                            CornerRadius="0,0,32,32" Visibility="Collapsed">
                        <StackPanel Margin="20,16">
                            <TextBlock Text="Bienvenue 👋" Foreground="{StaticResource TextBrush}"
                                       FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Margin="0,6,0,0" Foreground="{StaticResource SubTextBrush}" FontSize="12"
                                       TextWrapping="Wrap"
                                       Text="Survole l'île pour l'ouvrir. Onglets : Média, Minuteur, Fichiers. Glisse des fichiers dessus pour les garder sous la main."/>
                            <Button x:Name="FirstRunStartBtn" Content="Activer le démarrage avec Windows"
                                    Click="FirstRunEnableStart_Click" Style="{StaticResource PillBtn}"
                                    HorizontalAlignment="Left" Margin="0,12,0,0"/>
                            <Button Content="Terminer" Click="FirstRunDone_Click"
                                    Style="{StaticResource PillBtn}" HorizontalAlignment="Left" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="NotifBanner" Background="{StaticResource IslandBrush}"
                            CornerRadius="0,0,28,28" Visibility="Collapsed">
                        <Grid Margin="16,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="10"
                                    Background="#FF1E1E1E" Margin="0,0,12,0">
                                <Image x:Name="BannerIcon" Stretch="UniformToFill"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock x:Name="BannerApp" Text="" Foreground="{StaticResource AccentBrush}"
                                           FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock x:Name="BannerTitle" Text="" Foreground="{StaticResource TextBrush}"
                                           FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                <TextBlock x:Name="BannerBody" Text="" Foreground="{StaticResource SubTextBrush}"
                                           FontSize="12" TextTrimming="CharacterEllipsis" MaxWidth="270"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>
