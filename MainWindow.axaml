<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DynamicIsland.MainWindow"
        Title="Dynamic Island"
        Width="440" Height="320"
        SystemDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        CanResize="False"
        WindowStartupLocation="Manual">

    <Window.Styles>
        <Style Selector="Button.transport">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.transport:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#22FFFFFF" />
            <Setter Property="CornerRadius" Value="20" />
        </Style>

        <Style Selector="Button.tab">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#9A9A9A" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.tab:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#18FFFFFF" />
        </Style>

        <Style Selector="Button.pill">
            <Setter Property="Background" Value="#1E1E1E" />
            <Setter Property="Foreground" Value="#F2F2F2" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="CornerRadius" Value="15" />
            <Setter Property="Margin" Value="4,0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.pill:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#2C2C2C" />
        </Style>

        <Style Selector="Button.setting">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#F2F2F2" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.setting:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1AFFFFFF" />
        </Style>

        <Style Selector="Button.icon">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#9A9A9A" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.icon:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#18FFFFFF" />
        </Style>
    </Window.Styles>

    <Grid>
        <Border Name="Island"
                VerticalAlignment="Top" HorizontalAlignment="Center"
                Background="{StaticResource IslandBrush}"
                CornerRadius="0,0,22,22"
                Width="200" Height="34"
                ClipToBounds="True"
                BoxShadow="0 6 26 0 #88000000"
                DragDrop.AllowDrop="True">
            <Border.Transitions>
                <Transitions>
                    <DoubleTransition Property="Width" Duration="0:0:0.26" Easing="CubicEaseOut" />
                    <DoubleTransition Property="Height" Duration="0:0:0.26" Easing="CubicEaseOut" />
                    <CornerRadiusTransition Property="CornerRadius" Duration="0:0:0.2" />
                </Transitions>
            </Border.Transitions>

            <Panel>
                <!-- COMPACT -->
                <Grid Name="CompactView" Margin="14,0" ColumnDefinitions="Auto,*,Auto">
                    <Border Grid.Column="0" Width="18" Height="18" CornerRadius="5"
                            Background="#1E1E1E" VerticalAlignment="Center" Margin="0,0,8,0">
                        <Image Name="CompactArt" Stretch="UniformToFill" />
                    </Border>
                    <TextBlock Name="CompactClock" Grid.Column="1" Text="--:--"
                               Foreground="{StaticResource TextBrush}" FontSize="14" FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <StackPanel Name="CompactBars" Grid.Column="2" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="8,0,0,0" Height="16">
                        <Rectangle Width="3" Height="8" Fill="{StaticResource AccentBrush}" RadiusX="1.5" RadiusY="1.5" Margin="1,0" VerticalAlignment="Center">
                            <Rectangle.Styles>
                                <Style Selector="Rectangle">
                                    <Style.Animations>
                                        <Animation Duration="0:0:0.45" IterationCount="INFINITE" PlaybackDirection="Alternate">
                                            <KeyFrame Cue="0%"><Setter Property="Height" Value="5" /></KeyFrame>
                                            <KeyFrame Cue="100%"><Setter Property="Height" Value="14" /></KeyFrame>
                                        </Animation>
                                    </Style.Animations>
                                </Style>
                            </Rectangle.Styles>
                        </Rectangle>
                        <Rectangle Width="3" Height="14" Fill="{StaticResource AccentBrush}" RadiusX="1.5" RadiusY="1.5" Margin="1,0" VerticalAlignment="Center">
                            <Rectangle.Styles>
                                <Style Selector="Rectangle">
                                    <Style.Animations>
                                        <Animation Duration="0:0:0.6" IterationCount="INFINITE" PlaybackDirection="Alternate">
                                            <KeyFrame Cue="0%"><Setter Property="Height" Value="14" /></KeyFrame>
                                            <KeyFrame Cue="100%"><Setter Property="Height" Value="5" /></KeyFrame>
                                        </Animation>
                                    </Style.Animations>
                                </Style>
                            </Rectangle.Styles>
                        </Rectangle>
                        <Rectangle Width="3" Height="6" Fill="{StaticResource AccentBrush}" RadiusX="1.5" RadiusY="1.5" Margin="1,0" VerticalAlignment="Center">
                            <Rectangle.Styles>
                                <Style Selector="Rectangle">
                                    <Style.Animations>
                                        <Animation Duration="0:0:0.52" IterationCount="INFINITE" PlaybackDirection="Alternate">
                                            <KeyFrame Cue="0%"><Setter Property="Height" Value="6" /></KeyFrame>
                                            <KeyFrame Cue="100%"><Setter Property="Height" Value="13" /></KeyFrame>
                                        </Animation>
                                    </Style.Animations>
                                </Style>
                            </Rectangle.Styles>
                        </Rectangle>
                    </StackPanel>
                </Grid>

                <!-- EXPANDED -->
                <Grid Name="ExpandedView" Margin="18,12" Opacity="0" IsVisible="False"
                      RowDefinitions="Auto,*,Auto">
                    <Grid.Transitions>
                        <Transitions>
                            <DoubleTransition Property="Opacity" Duration="0:0:0.16" />
                        </Transitions>
                    </Grid.Transitions>

                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal" Spacing="2">
                            <Button Name="TabMediaBtn" Classes="tab" Content="Média" Click="TabMedia_Click" />
                            <Button Name="TabTimerBtn" Classes="tab" Content="Minuteur" Click="TabTimer_Click" />
                            <Button Name="TabFilesBtn" Classes="tab" Content="Fichiers" Click="TabFiles_Click" />
                        </StackPanel>
                        <Button Grid.Column="1" Classes="icon" Content="•••" Click="Settings_Click" VerticalAlignment="Top" />
                    </Grid>

                    <Panel Grid.Row="1">
                        <!-- MEDIA -->
                        <Grid Name="MediaPanel" RowDefinitions="Auto,Auto,*">
                            <Grid Grid.Row="0" ColumnDefinitions="Auto,*">
                                <Border Grid.Column="0" Width="52" Height="52" CornerRadius="12"
                                        Background="#1E1E1E" Margin="0,0,12,0">
                                    <Image Name="AlbumArt" Stretch="UniformToFill" />
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Name="TrackTitle" Text="Aucune lecture"
                                               Foreground="{StaticResource TextBrush}" FontSize="14" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Name="TrackArtist" Text="—"
                                               Foreground="{StaticResource SubTextBrush}" FontSize="12"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Grid>
                            <Panel Grid.Row="1" Height="4" Margin="0,12,0,0">
                                <Border CornerRadius="2" Background="{StaticResource TrackBrush}" />
                                <Border Name="ProgressFill" CornerRadius="2" Background="{StaticResource TextBrush}"
                                        HorizontalAlignment="Left" Width="0" />
                            </Panel>
                            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8"
                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Button Classes="transport" Click="Prev_Click">
                                    <Path Fill="{StaticResource TextBrush}" Data="M16,5 L8,11 L8,5 L6,5 L6,19 L8,19 L8,13 L16,19 Z" />
                                </Button>
                                <Button Name="PlayBtn" Classes="transport" Click="PlayPause_Click">
                                    <Path Name="PlayIcon" Fill="{StaticResource TextBrush}" Data="M7,4 L19,12 L7,20 Z" />
                                </Button>
                                <Button Classes="transport" Click="Next_Click">
                                    <Path Fill="{StaticResource TextBrush}" Data="M8,5 L16,11 L16,5 L18,5 L18,19 L16,19 L16,13 L8,19 Z" />
                                </Button>
                            </StackPanel>
                        </Grid>

                        <!-- TIMER -->
                        <StackPanel Name="TimerPanel" IsVisible="False" VerticalAlignment="Center">
                            <TextBlock Name="TimerDisplay" Text="00:00" HorizontalAlignment="Center"
                                       Foreground="{StaticResource TextBrush}" FontSize="40" FontWeight="Light" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                                <Button Classes="pill" Content="+1 min" Click="TimerPlus1_Click" />
                                <Button Classes="pill" Content="+5 min" Click="TimerPlus5_Click" />
                                <Button Classes="pill" Content="+10 min" Click="TimerPlus10_Click" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                                <Button Name="TimerStartBtn" Classes="pill" Content="Démarrer" Click="TimerStartPause_Click" />
                                <Button Classes="pill" Content="Réinit." Click="TimerReset_Click" />
                            </StackPanel>
                        </StackPanel>

                        <!-- FILES -->
                        <Panel Name="FilesPanel" IsVisible="False">
                            <TextBlock Name="ShelfHint" Text="Glisse des fichiers ici"
                                       Foreground="{StaticResource SubTextBrush}" FontSize="13"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <WrapPanel Name="ShelfPanel" />
                            </ScrollViewer>
                        </Panel>
                    </Panel>

                    <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                        <StackPanel Grid.Column="0">
                            <TextBlock Name="ClockText" Text="--:--"
                                       Foreground="{StaticResource TextBrush}" FontSize="13" FontWeight="SemiBold" />
                            <TextBlock Name="DateText" Text="—"
                                       Foreground="{StaticResource SubTextBrush}" FontSize="11" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                            <TextBlock Name="BtText" Text="" Foreground="{StaticResource TextBrush}"
                                       FontSize="12" VerticalAlignment="Center" IsVisible="False" />
                            <Border Width="22" Height="11" CornerRadius="2" BorderThickness="1.2"
                                    BorderBrush="{StaticResource TextBrush}" VerticalAlignment="Center">
                                <Border Name="BatteryFill" Background="{StaticResource AccentBrush}" CornerRadius="1"
                                        HorizontalAlignment="Left" Margin="1" Width="14" />
                            </Border>
                            <TextBlock Name="BatteryText" Text="--%"
                                       Foreground="{StaticResource TextBrush}" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Grid>

                <!-- SETTINGS -->
                <Border Name="SettingsPanel" Background="{StaticResource IslandBrush}" IsVisible="False" Opacity="0">
                    <Border.Transitions>
                        <Transitions><DoubleTransition Property="Opacity" Duration="0:0:0.14" /></Transitions>
                    </Border.Transitions>
                    <StackPanel Margin="18,12">
                        <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                            <TextBlock Text="Réglages" Foreground="{StaticResource TextBrush}"
                                       FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Classes="icon" Content="✕" Click="CloseSettings_Click" />
                        </Grid>
                        <Button Classes="setting" Content="Recentrer en haut" Click="Recenter_Click" />
                        <Button Name="AutoStartBtn" Classes="setting" Content="Démarrage auto" Click="AutoStart_Click" />
                        <Button Classes="setting" Content="Quitter" Foreground="#FF6B6B" Click="Quit_Click" />

                        <Border Height="1" Background="#22FFFFFF" Margin="0,8" />
                        <Grid ColumnDefinitions="Auto,*" Margin="2,2,0,0">
                            <Image Name="AboutLogo" Grid.Column="0" Width="34" Height="34" Margin="0,0,10,0" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Dynamic Island v1.0.0" Foreground="{StaticResource TextBrush}"
                                           FontSize="12" FontWeight="SemiBold" />
                                <TextBlock Text="par Karmahghosting · MIT" Foreground="{StaticResource SubTextBrush}" FontSize="11" />
                                <TextBlock Text="github.com/Karmahghosting/dynamic-island-windows"
                                           Foreground="{StaticResource AccentBrush}" FontSize="10" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- FIRST RUN -->
                <Border Name="FirstRunPanel" Background="{StaticResource IslandBrush}" IsVisible="False" Opacity="0">
                    <Border.Transitions>
                        <Transitions><DoubleTransition Property="Opacity" Duration="0:0:0.2" /></Transitions>
                    </Border.Transitions>
                    <StackPanel Margin="20,16">
                        <TextBlock Text="Bienvenue 👋" Foreground="{StaticResource TextBrush}" FontSize="16" FontWeight="SemiBold" />
                        <TextBlock Margin="0,6,0,0" Foreground="{StaticResource SubTextBrush}" FontSize="12" TextWrapping="Wrap"
                                   Text="Survole l'île pour l'ouvrir. Onglets : Média, Minuteur, Fichiers. Glisse des fichiers dessus pour les garder sous la main." />
                        <Button Name="FirstRunStartBtn" Classes="pill" Content="Activer le démarrage auto"
                                HorizontalAlignment="Left" Margin="0,12,0,0" Click="FirstRunEnableStart_Click" />
                        <Button Classes="pill" Content="Terminer" HorizontalAlignment="Left" Margin="0,8,0,0" Click="FirstRunDone_Click" />
                    </StackPanel>
                </Border>

                <!-- NOTIFICATION BANNER -->
                <Border Name="NotifBanner" Background="{StaticResource IslandBrush}" IsVisible="False" Opacity="0">
                    <Border.Transitions>
                        <Transitions><DoubleTransition Property="Opacity" Duration="0:0:0.16" /></Transitions>
                    </Border.Transitions>
                    <Grid Margin="16,10" ColumnDefinitions="Auto,*">
                        <Border Grid.Column="0" Width="40" Height="40" CornerRadius="10" Background="#1E1E1E" Margin="0,0,12,0">
                            <Image Name="BannerIcon" Stretch="UniformToFill" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Name="BannerApp" Text="" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="SemiBold" />
                            <TextBlock Name="BannerTitle" Text="" Foreground="{StaticResource TextBrush}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                            <TextBlock Name="BannerBody" Text="" Foreground="{StaticResource SubTextBrush}" FontSize="12" TextTrimming="CharacterEllipsis" MaxWidth="300" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Panel>
        </Border>
    </Grid>
</Window>
