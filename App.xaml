<Application x:Class="DynamicIsland.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="IslandBrush" Color="#FF0A0A0A"/>
        <SolidColorBrush x:Key="TextBrush" Color="#FFF2F2F2"/>
        <SolidColorBrush x:Key="SubTextBrush" Color="#FF9A9A9A"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FF34C759"/>
    </Application.Resources>
</Application>
