<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="DynamicIsland.App"
             RequestedThemeVariant="Dark">
    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
    <Application.Resources>
        <SolidColorBrush x:Key="IslandBrush" Color="#0A0A0A" />
        <SolidColorBrush x:Key="TextBrush" Color="#F2F2F2" />
        <SolidColorBrush x:Key="SubTextBrush" Color="#9A9A9A" />
        <SolidColorBrush x:Key="AccentBrush" Color="#34C759" />
        <SolidColorBrush x:Key="ChipBrush" Color="#222222" />
        <SolidColorBrush x:Key="TrackBrush" Color="#2A2A2A" />
    </Application.Resources>
</Application>
